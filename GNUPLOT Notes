// Plot levelset directly for smoother interface, along with smoothed mesh edges
>
set term pdfcairo enhanced color font 'Helvetica,10' size 5.0in,5.0in linewidth 2 enhanced
set output 'output.pdf'
unset key
set border 0
set xtics scale 0
set ytics scale 0
set format x ""
set format y ""
radius = 0.4501
phi(x,y) = radius - sqrt((x-0.5)**2 + (y-0.5)**2)
set parametric
set trange [0:2*pi]
plot "Th.dat" w l lc rgb "#48ABE8" linewidth 1, \
     "Thi.dat" w l lc rgb "black" linewidth 1.2, \
     0.5 + radius*cos(t), 0.5 + radius*sin(t) title "phi(x,y)=0" w l lc rgb "#FF4E36" linewidth 1.8
set output